---
import Layout from '@/layouts/Layout.astro'
import HeroSectionPage from '@/components/blocks/hero-section/hero-section'
import PopularDishes from '@/components/blocks/popular-dishes/popular-dishes'
import AboutUs from '@/components/blocks/about-us-section/about-us-page'
import Testimonials from '@/components/blocks/testimonials-section/testimonials-section'
import NewItems from '@/components/blocks/new-items-section/new-items'
import ContactUs from '@/components/blocks/contact-us-section/contact-us-page'
import Offers from '@/components/blocks/offers-section/offers-section'

import { getCollection } from 'astro:content'

// Fetch dynamic slides content
const slidesRaw = await getCollection('slides')
const menudata = slidesRaw.length > 0
  ? slidesRaw
      .map(slide => ({
        id: slide.data.id,
        img: slide.data.img,
        imgAlt: slide.data.imgAlt,
        userAvatar: slide.data.userAvatar,
        userComment: slide.data.userComment
      }))
      .sort((a, b) => a.id - b.id)
  : [
      {
        id: 1,
        img: '/images/hero-section/dish-01.webp',
        imgAlt: 'default-plate-1',
        userAvatar: '/images/hero-section/avatar-01.webp',
        userComment: 'No slides configured. Add slides in /admin/index.html!'
      }
    ]

// Fetch dynamic products content
const productsRaw = await getCollection('products')
const popularDishes = productsRaw.map(product => ({
  name: product.data.title,
  image: product.data.image,
  alt: product.data.alt,
  type: product.data.type,
  description: product.data.description
}))
import { stats } from '@/assets/data/about-us'
import { testimonials } from '@/assets/data/testimonials'
import { newItems } from '@/assets/data/new-items'
import { contactInfo } from '@/assets/data/contact-us'
import { GalleryImage } from '@/assets/data/offers'

// Page-specific SEO configuration
const pageTitle = ''
const pageDescription =
  'Enjoy fresh ingredients, thoughtfully prepared meals, and a welcoming space designed for memorable moments. Experience bistro dining made simple and delicious.'
const pageKeywords = 'astro template, shadcn ui, tailwind css, react components, restaurant'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Bistro - Restaurant Landing Page',
  description: pageDescription,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  },
  author: {
    '@type': 'Organization',
    name: 'Your Company Name'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSectionPage menudata={menudata} client:load />
  {popularDishes.length > 0 ? (
    <PopularDishes popularDishes={popularDishes} client:load />
  ) : (
    import.meta.env.DEV && (
      <div class="py-8 text-center text-muted-foreground border border-dashed rounded-md mx-auto max-w-7xl my-8">
        <p>No products configured. Go to <a href="/admin/index.html" class="underline font-semibold text-primary">/admin</a> to add some!</p>
      </div>
    )
  )}
  <AboutUs stats={stats} />
  <Testimonials testimonials={testimonials} client:load />
  <NewItems newItems={newItems} />
  <ContactUs contactInfo={contactInfo} />
  <Offers galleryImage={GalleryImage} />
</Layout>
