---
import Layout from '@/layouts/Layout.astro'
import HeroSectionPage from '@/components/blocks/hero-section/hero-section'
import PopularDishes from '@/components/blocks/popular-dishes/popular-dishes'
import AboutUs from '@/components/blocks/about-us-section/about-us-page'
import Testimonials from '@/components/blocks/testimonials-section/testimonials-section'
import NewItems from '@/components/blocks/new-items-section/new-items'
import ContactUs from '@/components/blocks/contact-us-section/contact-us-page'
import Offers from '@/components/blocks/offers-section/offers-section'

import { getCollection, getEntry } from 'astro:content'
import { iconMap } from '@/utils/icons'

// Import original template static data as fallbacks
import { menudata as defaultMenudata } from '@/assets/data/hero'
import { popularDishes as defaultPopularDishes } from '@/assets/data/popular-dishes'
import { stats as defaultStats } from '@/assets/data/about-us'
import { testimonials as defaultTestimonials } from '@/assets/data/testimonials'
import { newItems as defaultNewItems } from '@/assets/data/new-items'
import { contactInfo as defaultContactInfo } from '@/assets/data/contact-us'
import { GalleryImage as defaultGalleryImage } from '@/assets/data/offers'

// Fetch sections content from separate files in parallel
const [heroEntry, aboutEntry, contactEntry, promotionsEntry] = await Promise.all([
  getEntry('sections', 'hero'),
  getEntry('sections', 'about'),
  getEntry('sections', 'contact'),
  getEntry('sections', 'promotions')
])

// Fetch dynamic slides content directly from combined hero entry, falling back to original static list
const slidesRaw = heroEntry?.data.slides ?? []
const menudata = slidesRaw.length > 0
  ? slidesRaw
      .map(slide => ({
        id: slide.id,
        img: slide.img,
        imgAlt: slide.imgAlt,
        userAvatar: slide.userAvatar,
        userComment: slide.userComment
      }))
      .sort((a, b) => a.id - b.id)
  : defaultMenudata

// Fetch dynamic features, falling back to original static list
const productsRaw = await getCollection('features')
const popularDishes = productsRaw.length > 0
  ? productsRaw.map(product => ({
      name: product.data.title,
      image: product.data.image,
      alt: product.data.alt,
      type: product.data.type,
      description: product.data.description
    }))
  : defaultPopularDishes

// Fetch dynamic testimonials, falling back to original static list
const testimonialsRaw = await getCollection('testimonials')
const testimonials = testimonialsRaw.length > 0
  ? testimonialsRaw.map(t => ({
      name: t.data.title,
      avatar: t.data.avatar,
      rating: t.data.rating,
      content: t.data.content
    }))
  : defaultTestimonials

// Fetch dynamic blog posts, falling back to original static list
const blogRaw = await getCollection('blog')
const newItems = blogRaw.length > 0
  ? blogRaw.map(item => ({
      img: item.data.img,
      alt: item.data.alt,
      title: item.data.title,
      description: item.data.description,
      blogLink: item.data.blogLink
    }))
  : defaultNewItems

const heroData = {
  title: heroEntry?.data.title ?? "Savor the taste of perfection",
  description: heroEntry?.data.description ?? "Welcome to Restaurant where passion meets the plate.From sizzling appetisers to signature desserts, every dish is crafted to delight your senses."
}

const aboutData = {
  badge: aboutEntry?.data.badge ?? "About Us",
  title: aboutEntry?.data.title ?? "Our story & achievements",
  description: aboutEntry?.data.description ?? "At Restaurant, every dish tells a story. With years of dedication and a passion for fine dining, we've transformed the art of cooking into an unforgettable experience.",
  readMoreLink: aboutEntry?.data.readMoreLink ?? "#",
  image: aboutEntry?.data.image ?? "/images/about-us.webp",
  stats: aboutEntry?.data.stats ?? []
}

// Map stats dynamic Lucide React icons, falling back to original static list
const stats = aboutData.stats && aboutData.stats.length > 0
  ? aboutData.stats.map(stat => ({
      value: stat.value,
      description: [stat.line1, stat.line2],
      icon: iconMap[stat.icon] ?? iconMap.Trophy
    }))
  : defaultStats

// Fetch dynamic contact info, falling back to original static list
const contactInfoData = contactEntry?.data.contact
const contactInfo = contactInfoData && contactInfoData.length > 0
  ? contactInfoData.map(info => ({
      title: info.title,
      description: info.description,
      icon: iconMap[info.icon] ?? iconMap.PhoneIcon
    }))
  : defaultContactInfo

// Fetch dynamic promotions, falling back to original static list
const galleryImage = promotionsEntry?.data.promotions && promotionsEntry?.data.promotions.length > 0
  ? promotionsEntry.data.promotions
  : defaultGalleryImage

// Page-specific SEO configuration
const pageTitle = ''
const pageDescription =
  'Enjoy fresh ingredients, thoughtfully prepared meals, and a welcoming space designed for memorable moments. Experience bistro dining made simple and delicious.'
const pageKeywords = 'astro template, shadcn ui, tailwind css, react components, restaurant'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Bistro - Restaurant Landing Page',
  description: pageDescription,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  },
  author: {
    '@type': 'Organization',
    name: 'Your Company Name'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSectionPage 
    title={heroData.title} 
    description={heroData.description} 
    menudata={menudata} 
    client:load 
  />
  <PopularDishes popularDishes={popularDishes} client:load />
  <AboutUs 
    badge={aboutData.badge}
    title={aboutData.title}
    description={aboutData.description}
    readMoreLink={aboutData.readMoreLink}
    image={aboutData.image}
    stats={stats} 
  />
  <Testimonials testimonials={testimonials} client:load />
  <NewItems newItems={newItems} />
  <ContactUs 
    badge={contactEntry?.data.badge}
    title={contactEntry?.data.title}
    description={contactEntry?.data.description}
    image={contactEntry?.data.image}
    rightTitle={contactEntry?.data.rightTitle}
    rightDescription={contactEntry?.data.rightDescription}
    contactInfo={contactInfo} 
  />
  <Offers galleryImage={galleryImage} />
</Layout>
