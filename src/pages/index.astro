---
import Layout from '@/layouts/Layout.astro'
import HeroSectionPage from '@/components/blocks/hero-section/hero-section'
import PopularDishes from '@/components/blocks/popular-dishes/popular-dishes'
import AboutUs from '@/components/blocks/about-us-section/about-us-page'
import Testimonials from '@/components/blocks/testimonials-section/testimonials-section'
import NewItems from '@/components/blocks/new-items-section/new-items'
import ContactUs from '@/components/blocks/contact-us-section/contact-us-page'
import Offers from '@/components/blocks/offers-section/offers-section'

import { getCollection, getEntry } from 'astro:content'
import { iconMap } from '@/utils/icons'

// Fetch sections content from separate files
const heroEntry = await getEntry('sections', 'hero')
const aboutEntry = await getEntry('sections', 'about')
const contactEntry = await getEntry('sections', 'contact')
const promotionsEntry = await getEntry('sections', 'promotions')

// Fetch dynamic slides content directly from combined hero entry
const slidesRaw = heroEntry?.data.slides ?? []
const menudata = slidesRaw.length > 0
  ? slidesRaw
      .map(slide => ({
        id: slide.id,
        img: slide.img,
        imgAlt: slide.imgAlt,
        userAvatar: slide.userAvatar,
        userComment: slide.userComment
      }))
      .sort((a, b) => a.id - b.id)
  : [
      {
        id: 1,
        img: '/images/hero-section/dish-01.webp',
        imgAlt: 'default-plate-1',
        userAvatar: '/images/hero-section/avatar-01.webp',
        userComment: 'No slides configured. Add slides in /admin/index.html!'
      }
    ]

// Fetch dynamic products content
const productsRaw = await getCollection('features')
const popularDishes = productsRaw.map(product => ({
  name: product.data.title,
  image: product.data.image,
  alt: product.data.alt,
  type: product.data.type,
  description: product.data.description
}))

// Fetch dynamic testimonials content
const testimonialsRaw = await getCollection('testimonials')
const testimonials = testimonialsRaw.length > 0
  ? testimonialsRaw.map(t => ({
      name: t.data.title,
      avatar: t.data.avatar,
      rating: t.data.rating,
      content: t.data.content
    }))
  : []

// Fetch dynamic blog post content
const blogRaw = await getCollection('blog')
const newItems = blogRaw.length > 0
  ? blogRaw.map(item => ({
      img: item.data.img,
      alt: item.data.alt,
      title: item.data.title,
      description: item.data.description,
      blogLink: item.data.blogLink
    }))
  : []

const heroData = {
  title: heroEntry?.data.title ?? "Savor the taste of perfection",
  description: heroEntry?.data.description ?? "Welcome to Restaurant where passion meets the plate.From sizzling appetisers to signature desserts, every dish is crafted to delight your senses."
}

const aboutData = {
  badge: aboutEntry?.data.badge ?? "About Us",
  title: aboutEntry?.data.title ?? "Our story & achievements",
  description: aboutEntry?.data.description ?? "At Restaurant, every dish tells a story. With years of dedication and a passion for fine dining, we've transformed the art of cooking into an unforgettable experience.",
  readMoreLink: aboutEntry?.data.readMoreLink ?? "#",
  image: aboutEntry?.data.image ?? "/images/about-us.webp",
  stats: aboutEntry?.data.stats ?? []
}

// Map stats dynamic Lucide React icons
const stats = aboutData.stats && aboutData.stats.length > 0
  ? aboutData.stats.map(stat => ({
      value: stat.value,
      description: [stat.line1, stat.line2],
      icon: iconMap[stat.icon] ?? iconMap.Trophy
    }))
  : []

// Fetch dynamic contact info
const contactInfoData = contactEntry?.data.contact ?? [
  {
    title: 'Open Hours',
    icon: 'Clock8Icon',
    description: 'Monday-Friday\n8:00 am to 5:00 pm'
  },
  {
    title: 'Our Address',
    icon: 'MapPinIcon',
    description: '802 Perston Rd,Maine\n96812, USA'
  },
  {
    title: 'Email',
    icon: 'Mail',
    description: 'info@seliziakitchen.com'
  },
  {
    title: 'Phone',
    icon: 'PhoneIcon',
    description: '+1 (123) 456-7890'
  }
]

const contactInfo = contactInfoData.map(info => ({
  title: info.title,
  description: info.description,
  icon: iconMap[info.icon] ?? iconMap.PhoneIcon
}))

// Fetch dynamic promotions content
const galleryImage = promotionsEntry?.data.promotions ?? [
  {
    src: '/images/offers/offers-image-01.webp',
    alt: 'Launch deal',
    className: 'col-span-2 row-span-2',
    offerText: {
      text: 'Lunch Deal - $9.99',
      className: 'xl:top-6 xl:right-6 top-3 right-3'
    },
    offerButton: {
      text: 'Book your table',
      link: '#',
      className: 'xl:top-19.5 xl:right-6 top-12 right-3'
    }
  },
  {
    src: '/images/offers/offers-image-02.webp',
    alt: 'Bogo special',
    className: 'col-span-2 max-h-60',
    offerText: {
      text: 'BOGO Special',
      className: 'xl:bottom-18.5 xl:left-4 bottom-13 left-3'
    },
    offerButton: {
      text: 'Claim offer',
      link: '#',
      className: 'xl:bottom-5 xl:left-4 bottom-2 left-3'
    }
  },
  {
    src: '/images/offers/offers-image-03.webp',
    alt: 'Family meal',
    className: 'col-span-2 max-h-60',
    offerText: {
      text: 'Family Meal – $29.99',
      className: 'xl:top-5 xl:right-12 top-3 right-3'
    },
    offerButton: {
      text: 'Book your table',
      link: '#',
      className: 'xl:top-19 xl:right-12 top-11 right-3'
    }
  }
]

// Page-specific SEO configuration
const pageTitle = ''
const pageDescription =
  'Enjoy fresh ingredients, thoughtfully prepared meals, and a welcoming space designed for memorable moments. Experience bistro dining made simple and delicious.'
const pageKeywords = 'astro template, shadcn ui, tailwind css, react components, restaurant'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Bistro - Restaurant Landing Page',
  description: pageDescription,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  },
  author: {
    '@type': 'Organization',
    name: 'Your Company Name'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSectionPage 
    title={heroData.title} 
    description={heroData.description} 
    menudata={menudata} 
    client:load 
  />
  {popularDishes.length > 0 ? (
    <PopularDishes popularDishes={popularDishes} client:load />
  ) : (
    import.meta.env.DEV && (
      <div class="py-8 text-center text-muted-foreground border border-dashed rounded-md mx-auto max-w-7xl my-8">
        <p>No products configured. Go to <a href="/admin/index.html" class="underline font-semibold text-primary">/admin</a> to add some!</p>
      </div>
    )
  )}
  
  {stats.length > 0 ? (
    <AboutUs 
      badge={aboutData.badge}
      title={aboutData.title}
      description={aboutData.description}
      readMoreLink={aboutData.readMoreLink}
      image={aboutData.image}
      stats={stats} 
    />
  ) : (
    import.meta.env.DEV && (
      <div class="py-8 text-center text-muted-foreground border border-dashed rounded-md mx-auto max-w-7xl my-8">
        <p>No stats configured for About section. Go to <a href="/admin/index.html" class="underline font-semibold text-primary">/admin</a> to add stats!</p>
      </div>
    )
  )}
  
  {testimonials.length > 0 ? (
    <Testimonials testimonials={testimonials} client:load />
  ) : (
    import.meta.env.DEV && (
      <div class="py-8 text-center text-muted-foreground border border-dashed rounded-md mx-auto max-w-7xl my-8">
        <p>No testimonials configured. Go to <a href="/admin/index.html" class="underline font-semibold text-primary">/admin</a> to add testimonials!</p>
      </div>
    )
  )}
  
  {newItems.length > 0 ? (
    <NewItems newItems={newItems} />
  ) : (
    import.meta.env.DEV && (
      <div class="py-8 text-center text-muted-foreground border border-dashed rounded-md mx-auto max-w-7xl my-8">
        <p>No blog posts configured. Go to <a href="/admin/index.html" class="underline font-semibold text-primary">/admin</a> to add posts!</p>
      </div>
    )
  )}
  
  <ContactUs contactInfo={contactInfo} />
  <Offers galleryImage={galleryImage} />
</Layout>
